# Garmin Connect credentials
# Copy this file to .env and fill in your real credentials
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=your_password

# Vitalis API (used by scripts/read_nutrition.py, scripts/publish_summary.py, etc.)
# Production API URL includes the /api suffix
VITALIS_API_URL=https://func-vitalis-api.azurewebsites.net/api
VITALIS_API_KEY=your_function_api_key
