# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/
mobile/.dart_tool/
.pytest_cache/
.coverage
htmlcov/
*.log

# Environment
.env
.env.local
.env.*.local

# Azure Functions local secrets
api/local.settings.json

# Secrets — FCM service account, Firebase config (never commit)
data/.secrets/
**/google-services.json
**/GoogleService-Info.plist

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Data — keep structure, ignore user-specific files
data/uploads/*
!data/uploads/.gitkeep
data/.garmin_tokens/
data/.tessdata/
data/synced/*
!data/synced/.gitkeep
data/profile.yaml
data/summaries/*.md
!data/samples/.gitkeep
!data/summaries/.gitkeep
data/csv from garmin/
data/goal_program.json
data/training_plan.json

# Cloud backups (full personal health data snapshots — never commit)
data/cloud-backup-*/

# Multi-user staging — each cloud user's personal health data, medical docs,
# generated reports, and Garmin OAuth tokens live under data/users/<oid>/.
# NEVER commit any user's data; keep only the structural docs.
data/users/*
!data/users/.gitkeep
!data/users/README.md

# Medical records — all personal documents ignored
data/medical/blood_tests/*
data/medical/doctor_visits/*
data/medical/imaging/*
data/medical/prescriptions/*
data/medical/vaccinations/*
data/medical/index.json
data/medical/context.md
!data/medical/.gitkeep
!data/medical/blood_tests/.gitkeep
!data/medical/doctor_visits/.gitkeep
!data/medical/imaging/.gitkeep
!data/medical/prescriptions/.gitkeep
!data/medical/vaccinations/.gitkeep

# Personal health data & temp diagnostic dumps (never upload — kept local only)
/_*.json
data/longevity-plan.md
data/profile.yaml.broken-*

# One-off / personal helper scripts (underscore-prefixed convention)
scripts/_*.py

# Local artifacts
%TEMP%/
tmp-api-deploy/
tmp-*.zip

# OneDrive conflict copies
*-CPC-*.py
*-CPC-*.dart
*-CPC-*.md
*-CPC-*.xml
*-CPC-*.kt
*-CPC-*.flutter-plugins-dependencies

# Legacy (safe to remove once fully cleaned)
frontend/
backend/
